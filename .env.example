# .env.example — copy to .env and fill in your keys
# Never commit .env — it's in .gitignore

# ── YouTube Data API v3 ──────────────────────────────────────────────────────
# Get free keys at https://console.cloud.google.com/
# Each key = 10,000 quota units per day. Use multiple keys for more headroom.
#
# Option A: comma-separated (preferred)
YOUTUBE_API_KEYS=AIza_first_key,AIza_second_key,AIza_third_key

# Option B: numbered (also works — scraper picks up all of them)
# YOUTUBE_API_KEY=AIza_first_key
# YOUTUBE_API_KEY_2=AIza_second_key
# YOUTUBE_API_KEY_3=AIza_third_key

# ── Google Gemini API (for viral_analyzer.py) ───────────────────────────────
# Get one free at https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here
